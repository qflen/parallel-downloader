# parallel-downloader: high-level component overview, sized for README embed.
# Render with:  d2 --layout=elk docs/architecture.d2 docs/architecture.svg
#               d2 --layout=elk docs/architecture.d2 docs/architecture.png
#
# This is the compact view: three packages, key components, design-pattern stereotypes.
# The detailed shape-level diagram (lifecycle steps, every adapter / strategy / observer
# variant, every cross-package edge) is in docs/architecture-detailed.d2 / .svg.

direction: down

classes: {
  pattern-template:  { style: { fill: "#FFD6E0"; stroke: "#1F1F1F"; font-size: 30 } }
  pattern-builder:   { style: { fill: "#E2D5F0"; stroke: "#1F1F1F"; font-size: 30 } }
  pattern-observer:  { style: { fill: "#FFF6BF"; stroke: "#1F1F1F"; font-size: 30 } }
  pattern-sealed:    { style: { fill: "#DFEFFA"; stroke: "#1F1F1F"; font-size: 30 } }
  pattern-adapter:   { style: { fill: "#CDE9C7"; stroke: "#1F1F1F"; font-size: 30 } }
  pattern-decorator: { style: { fill: "#DDEEFF"; stroke: "#1F1F1F"; font-size: 30 } }
  pattern-strategy:  { style: { fill: "#FFE7BA"; stroke: "#1F1F1F"; font-size: 30 } }
  edge:              { style: { font-size: 28; bold: true } }
}

orchestration: "orchestration" {
  style: { fill: "#FAFAFA"; stroke: "#888888"; font-size: 36; bold: true }

  FileDownloader: "FileDownloader\n«Template Method»" {
    class: pattern-template
  }

  DownloadConfig: "DownloadConfig\n«Builder DSL»" {
    class: pattern-builder
  }

  Observers: "ProgressListener / Flow / Telemetry\n«Observer»" {
    class: pattern-observer
  }

  DownloadResult: "DownloadResult\n«Sealed result»" {
    class: pattern-sealed
  }
}

transport: "transport" {
  style: { fill: "#FAFAFA"; stroke: "#888888"; font-size: 36; bold: true }

  Port: "HttpRangeFetcher\n«Adapter / Port»" {
    class: pattern-adapter
  }

  Adapter: "JdkHttpRangeFetcher\n«Adapter (production)»" {
    class: pattern-adapter
  }

  Decorator: "RetryingHttpRangeFetcher\n«Decorator»" {
    class: pattern-decorator
  }
}

retry: "retry" {
  style: { fill: "#FAFAFA"; stroke: "#888888"; font-size: 36; bold: true }

  Policy: "RetryPolicy\n«Strategy»" {
    class: pattern-strategy
  }
}

orchestration.FileDownloader -> orchestration.DownloadConfig: "reads"        { class: edge }
orchestration.FileDownloader -> orchestration.Observers: "notifies"          { class: edge }
orchestration.FileDownloader -> orchestration.DownloadResult: "returns"      { class: edge; style.stroke-dash: 4 }
orchestration.FileDownloader -> transport.Port: "uses"                       { class: edge }

transport.Adapter -> transport.Port: "implements"                            { class: edge; style.stroke-dash: 4 }
transport.Decorator -> transport.Port: "implements + wraps"                  { class: edge }
transport.Decorator -> retry.Policy: "applies"                               { class: edge }
